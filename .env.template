# Handler One Discord Bot — Environment Configuration
# Copy to .env and fill in real values. Never commit .env.

# --- Required ---

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# Discord bot token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=

# --- Optional ---

# Claude model to use. Default: claude-haiku-4-5 (fast + cheap, $1/$5 per 1M tokens).
# Alternatives: claude-sonnet-4-6 (smarter), claude-opus-4-7 (most capable).
CLAUDE_MODEL=claude-haiku-4-5

# Max output tokens per response. Discord caps individual messages at 2000 chars,
# but long answers chunk across messages. 8000 is plenty for chat.
CLAUDE_MAX_TOKENS=8000

# Effort level — only used by Opus 4.6/4.7 and Sonnet 4.6. Haiku 4.5 ignores this.
# Values: low | medium | high | xhigh (Opus 4.7 only) | max (Opus only).
CLAUDE_EFFORT=high

# How many recent channel messages to feed Claude as context per turn.
# Bot is stateless — Discord channel is the source of truth, fetched fresh each turn.
HANDLER_HISTORY_FETCH_LIMIT=30

# Per-query timeout in seconds before the bot gives up.
HANDLER_QUERY_TIMEOUT=120

# Comma-separated Discord user IDs allowed to talk to the bot.
# Leave empty to allow anyone in any guild/DM the bot can see.
# Example: ALLOWED_USER_IDS=123456789012345678,234567890123456789
ALLOWED_USER_IDS=

# Comma-separated Discord guild (server) IDs the bot is restricted to.
# Leave empty to allow any guild the bot is invited to.
ALLOWED_GUILD_IDS=

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
